{
  "name": "@rey-one/shared",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json --outDir dist/cjs && tsc -p tsconfig.esm.json && tsc-alias -p tsconfig.json --outDir dist/cjs && tsc-alias -p tsconfig.esm.json --outDir dist/esm",
    "dev:cjs": "tsc-watch -p tsconfig.json --outDir dist/cjs --onSuccess \"tsc-alias -p tsconfig.json --outDir dist/cjs\"",
    "dev:esm": "tsc-watch -p tsconfig.esm.json --onSuccess \"tsc-alias -p tsconfig.esm.json --outDir dist/esm\"",
    "dev": "rimraf dist && concurrently \"pnpm dev:cjs\" \"pnpm dev:esm\""
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.3"
  }
}
